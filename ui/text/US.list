// Setting common enable local proxy telegram
str_checkbox_enable_proxy_tg_title=📱 Proxy for Telegram
str_checkbox_enable_proxy_tg_description=🔒 Local proxy for Telegram
Creates a proxy server on your device. It does not connect to external servers and works locally to bypass blocks.

// Setting checkbox zapret winws enable
str_unblock_enable_title=🔓 Enable Zapret2 (winws2)
str_unblock_enable_description=Primary bypass mode based on the Zapret2 DPI evader (winws2).
Analyzes and modifies network packets in real time, altering TLS handshake parameters (ClientHello) and other signatures.
Bypasses most types of blocking without redirecting traffic to external servers.
Works locally and requires no additional proxies.

// Setting checkbox unblock enable services
str_unblock_enable_discord_title=🎤 Discord
str_unblock_enable_discord_description=Bypass Discord blocking.
→ Enable together with Cloudflare.

str_unblock_enable_messengers_title=💬 Messengers
str_unblock_enable_messengers_description=Bypass blocking for popular messengers (Telegram, Signal).

str_unblock_enable_cloudflare_title=☁ Cloudflare
str_unblock_enable_cloudflare_description=Bypass Cloudflare blocking — a protection service used by many websites.
Enable if sites behind Cloudflare are unavailable.

str_unblock_enable_instagram_title=📸 Instagram
str_unblock_enable_instagram_description=Bypass Instagram blocking.

str_unblock_enable_facebook_title=📘 Facebook
str_unblock_enable_facebook_description=Bypass Facebook and related services (Instagram, Messenger).

str_unblock_enable_torrent_tracers_title=📥 Torrent trackers
str_unblock_enable_torrent_tracers_description=Bypass blocking of torrent trackers (Rutor, RuTracker, etc.).

str_unblock_enable_x.com_title=🐦 X.com
str_unblock_enable_x.com_description=Bypass X (Twitter) blocking.

str_unblock_enable_youtube_title=🎬 YouTube
str_unblock_enable_youtube_description=Bypass YouTube blocking.

str_unblock_enable_game_mod_title=🎮 Online games
str_unblock_enable_game_mod_description=Mode for game servers.
⚠ May trigger anti-cheat, break other services.
Enable only if you experience issues in games.

str_unblock_enable_torproject_title=🧅 Torproject
str_unblock_enable_torproject_description=Bypass Tor blocking.

// Setting checkbox unblock enable TLD
str_unblock_enable_tld_title=🌐 TLD filtering mode
str_unblock_enable_tld_description=TLD filtering:
When enabled, blocking bypass is applied to all domain zones listed in configs\blacklist\tld.list (com, net, ua, and others).

