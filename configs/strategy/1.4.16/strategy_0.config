--lua-desync=hostfakesplit:blob=fake_default_udp:host=www.google.com:midhost=host-2:seqovl=-1500:seqovl_pattern=fake_default_udp:repeats=8:badsum
--lua-desync=hostfakesplit:blob=QUIC_GOOGLE:host=www.google.com:midhost=host-2:seqovl=-1500:seqovl_pattern=fake_default_udp:repeats=8:badsum
--lua-desync=hostfakesplit:blob=QUIC_VK:host=vk.com:midhost=host-2:seqovl=-1000:seqovl_pattern=fake_default_udp:repeats=6:badsum
