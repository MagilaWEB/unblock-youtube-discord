--lua-desync=hostfakesplit:blob=TLS_VK_KYBER:tcp_ts=-600000:ip_id=zero:host=vk.com:midhost=host-2:repeats=6
--lua-desync=hostfakesplit:blob=TLS_ALERT:tcp_ts=-600000:ip_id=zero:host=www.google.com:midhost=host-2:repeats=6
--lua-desync=hostfakesplit:blob=TLS_MAX:tcp_ts=-600000:ip_id=zero:host=www.max.ru:midhost=host-2:repeats=6
--lua-desync=hostfakesplit:blob=TLS_SHORT:tcp_ts=-600000:ip_id=zero:host=short.com:midhost=host-2:repeats=6
--lua-desync=hostfakesplit:blob=TLS_SBERBANK:tcp_ts=-600000:ip_id=zero:host=www.sberbank.ru:midhost=host-2:repeats=6
--lua-desync=hostfakesplit:blob=TLS_RUTRACKER:tcp_ts=-600000:ip_id=zero:host=www.max.ru:midhost=host-2:repeats=6
--lua-desync=hostfakesplit:blob=TLS_RUTRACKER_KYBER:tcp_ts=-600000:ip_id=zero:host=www.max.ru:midhost=host-2:repeats=6


[game_mod]
