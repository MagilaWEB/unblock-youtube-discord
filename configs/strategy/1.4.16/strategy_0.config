--new
--filter-tcp=80,443,%%GamePort%
%IP-SETLIST%
%DOMAINS-EXCLUDE%
%IP-EXCLUDE%
--lua-desync=circular:fails=2:time=3000:maxtime=500:interval=10:retrans=3:maxseq=32768:reset
--lua-desync=hostfakesplit:blob=TLS_GOOGLE:tcp_ts=-600000:ip_id=zero:host=www.google.com:midhost=host-2:repeats=6
