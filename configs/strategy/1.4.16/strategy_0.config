--lua-desync=fakedsplit:blob=QUIC_VK:seqovl_pattern=fake_default_udp:seqovl=-1000:repeats=6:badsum
--lua-desync=fakedsplit:blob=QUIC_FACEBOOK:seqovl_pattern=fake_default_udp:seqovl=-1000:repeats=8:badsum
