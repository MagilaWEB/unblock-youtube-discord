[START]
--wf-tcp-in=80,443,%DiscordPort%
--wf-udp-in=443,%DiscordPortUPD%,%GamePort%
--wf-tcp-out=80,443,%DiscordPort%
--wf-udp-out=443,%DiscordPortUPD%,%GamePort%

%INIT_LUA%
%INIT_BLOB%
--blob=fake_default_udp:0x00
--blob=fake_default_tcp:0x00

--filter-udp=443
%BLOCKLIST%
%DOMAINS-EXCLUDE%
%IP-EXCLUDE%
--lua-desync=circular:key=udp_rules_domain:fails=1:udp_out=4:udp_in=1
--lua-desync=fake:blob=fake_default_udp:repeats=8
--lua-desync=fake:blob=QUIC_GOOGLE:repeats=8
--lua-desync=fake:blob=QUIC_RUTRACKER:repeats=8
--lua-desync=fake:blob=QUIC_RUTRACKER_KYBER1:repeats=8
--lua-desync=fake:blob=QUIC_RUTRACKER_KYBER2:repeats=8
--lua-desync=fake:blob=QUIC_VK:repeats=6
--lua-desync=fake:blob=QUIC_FACEBOOK:repeats=8
--lua-desync=fake:blob=QUIC_FACEBOOK_QUICHE:repeats=8
--lua-desync=fake:blob=QUIC_SHORT:repeats=8
--lua-desync=fake:blob=QUIC_SHORT_HEADER:repeats=8

[discord]
--new
--filter-udp=%DiscordPortUPD%
--filter-l7=discord,stun,quic
--payload=quic_initial,discord_ip_discovery,stun
--lua-desync=circular:key=udp_rules_discord:fails=1:udp_out=4:udp_in=1
--lua-desync=fake:blob=fake_default_udp:repeats=8
--lua-desync=fake:blob=QUIC_GOOGLE:repeats=8
--lua-desync=fake:blob=QUIC_RUTRACKER:repeats=8
--lua-desync=fake:blob=QUIC_RUTRACKER_KYBER1:repeats=8
--lua-desync=fake:blob=QUIC_RUTRACKER_KYBER2:repeats=8
--lua-desync=fake:blob=QUIC_VK:repeats=6
--lua-desync=fake:blob=QUIC_FACEBOOK:repeats=8
--lua-desync=fake:blob=QUIC_FACEBOOK_QUICHE:repeats=8
--lua-desync=fake:blob=QUIC_SHORT:repeats=8
--lua-desync=fake:blob=QUIC_SHORT_HEADER:repeats=8

[END]
--new
