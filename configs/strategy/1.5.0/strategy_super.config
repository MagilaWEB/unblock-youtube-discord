[START]
--wf-tcp-in=80,443,%MessengersPort%,%DiscordPort%,%GamePort%,%TorrentPort%
--wf-udp-in=%MessengersPort%,%MessengersPortUPD%,%DiscordPortUPD%,%GamePort%,%TorrentPort%
--wf-tcp-out=80,443,%MessengersPort%,%DiscordPort%,%GamePort%,%TorrentPort%
--wf-udp-out=443,%MessengersPort%,%MessengersPortUPD%,%DiscordPortUPD%,%GamePort%,%TorrentPort%

%INIT_LUA%
%INIT_BLOB%
--blob=fake_default_udp:0x00000000000000000000000000000000

[discord]
--filter-udp=19294-19344,50000-50100
--filter-l7=discord,stun,quic
--payload=quic_initial,discord_ip_discovery,stun
--lua-desync=circular:fails=1:maxtime=30:udp_out=4:udp_in=4:reset
--lua-desync=fake:blob=fake_default_udp:repeats=6:strategy=1
--lua-desync=fake:blob=QUIC_GOOGLE:repeats=6:strategy=2
--lua-desync=fake:blob=QUIC_VK:repeats=6:strategy=3
--lua-desync=fake:blob=QUIC_RUTRACKER:repeats=6:strategy=4
--lua-desync=fake:blob=QUIC_RUTRACKER_KYBER1:repeats=6:strategy=5
--lua-desync=fake:blob=QUIC_RUTRACKER_KYBER2:repeats=6:strategy=6
--lua-desync=fake:blob=QUIC_FACEBOOK:repeats=6:strategy=7
--lua-desync=fake:blob=QUIC_FACEBOOK_QUICHE:repeats=6:strategy=8
--lua-desync=fake:blob=QUIC_SHORT:repeats=6:strategy=9
--lua-desync=fake:blob=QUIC_SHORT_HEADER:repeats=6:strategy=10

--new
--filter-tcp=1080,2053,2083,2087,2096,8443
--filter-l7=http,tls
--hostlist-domains=discord.media
--payload=tls_client_hello,http_req
--lua-desync=circular:fails=2:time=300:maxtime=150:interval=10:retrans=3:maxseq=32768:reset
--lua-desync=fake:blob=TLS_GOOGLE:repeats=6:tcp_ts=-600000:seqovl_pattern=TLS_GOOGLE:strategy=1
--lua-desync=fakedsplit:pattern=0x00:repeats=6:tcp_ts=-600000:strategy=2
--lua-desync=fake:blob=TLS_GOOGLE:repeats=6:tcp_seq=2:seqovl_pattern=TLS_GOOGLE:strategy=3
--lua-desync=fake:blob=fake_default_http:repeats=6:tcp_ts=-600000:strategy=4
--lua-desync=multisplit:pos=2:seqovl=681:seqovl_pattern=TLS_GOOGLE:repeats=8:strategy=5

[END]
--new
--filter-tcp=80,443
--filter-l7=http,tls,mtproto
%BLOCKLIST%
%DOMAINS-EXCLUDE%
