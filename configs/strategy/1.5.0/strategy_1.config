[START]
--wf-tcp-in=80,443,%MessengersPort%,%DiscordPort%,%GamePort%,%TorrentPort%
--wf-udp-in=%MessengersPort%,%MessengersPortUPD%,%DiscordPortUPD%,%GamePort%,%TorrentPort%
--wf-tcp-out=80,443,%MessengersPort%,%DiscordPort%,%GamePort%,%TorrentPort%
--wf-udp-out=443,%MessengersPort%,%MessengersPortUPD%,%DiscordPortUPD%,%GamePort%,%TorrentPort%

%INIT_LUA%
%INIT_BLOB%
--blob=fake_default_udp:0x00000000000000000000000000000000

[discord]
--filter-udp=19294-19344,50000-50100
--filter-l7=discord,stun,quic
--lua-desync=circular:fails=1:maxtime=30:udp_out=4:udp_in=4:reset
--payload=quic_initial,discord_ip_discovery,stun
--lua-desync=fake:blob=QUIC_VK:repeats=6:strategy=1
--lua-desync=fake:blob=fake_default_udp:strategy=2
--lua-desync=fake:blob=fake_default_udp:repeats=6:strategy=3
--lua-desync=fake:blob=QUIC_GOOGLE:repeats=6:ip_autottl=2,3-20:ip6_autottl=2,3-20:payload=unknown:strategy=4
--lua-desync=fake:blob=fake_default_udp:repeats=2:out_range=-d10:strategy=5
--lua-desync=fake:blob=fake_default_udp:out_range=-d10:strategy=6
--lua-desync=fake:blob=QUIC_GOOGLE:repeats=6:out_range=-d3:strategy=7
--lua-desync=fake:blob=QUIC_GOOGLE:repeats=6:out_range=-n4:strategy=8
--lua-desync=fake:blob=fake_default_udp:out_range=-n3:strategy=9
--lua-desync=send:repeats=2:ip_autottl=0,3-20:strategy=10
--lua-desync=fake:blob=fake_default_udp:ip_autottl=0,3-20:out_range=-d10:strategy=11
--lua-desync=send:repeats=2:ip6_autottl=0,3-20:strategy=12
--lua-desync=fake:blob=fake_default_udp:ip6_autottl=0,3-20:out_range=-d10:strategy=13

--new
--filter-tcp=2053,2083,2087,2096,8443
--filter-l7=http,tls
--hostlist-domains=discord.media
--payload=tls_client_hello,http_req
--lua-desync=circular:fails=1:maxtime=30:retrans=2:maxseq=16384:reset
--lua-desync=fake:blob=TLS_GOOGLE:seqovl_pattern=TLS_GOOGLE:tcp_ts=-10000:tcp_seq=400:repeats=8:strategy=1
--lua-desync=fake:blob=TLS_RUTRACKER:seqovl_pattern=TLS_RUTRACKER:tcp_ts=-10000:tcp_seq=400:repeats=8:strategy=2
--lua-desync=fake:blob=TLS_SHORT:seqovl_pattern=TLS_SHORT:tcp_ts=10000:tcp_seq=400:repeats=8:strategy=3
--lua-desync=fake:blob=TLS_MAX:seqovl_pattern=TLS_MAX:tcp_ts=-10000:tcp_seq=400:repeats=8:strategy=4
--lua-desync=hostfakesplit:host=ozon.ru:tcp_ts=-1000:tcp_md5:seqovl_pattern=TLS_IANA_BIGSIZE:repeats=4:strategy=5

[END]
--new
--filter-tcp=80,443
--filter-l7=http,tls
%BLOCKLIST%
%DOMAINS-EXCLUDE%
%IP-EXCLUDE%
--payload=all
--lua-desync=circular:fails=1:maxtime=30:retrans=2:maxseq=16384:reset
--lua-desync=multidisorder:pos=1,midsld:strategy=1
--lua-desync=send:repeats=2:strategy=2
--lua-desync=multidisorder:ip_id=zero:pos=1,midsld:tcp_ack=-66000:strategy=3
--lua-desync=multidisorder:ip_id=zero:pos=1,midsld:ip_autottl=-1,3-20:ip6_autottl=-1,3-20:strategy=4
--lua-desync=multidisorder:ip_id=zero:pos=1,midsld:tcp_md5:strategy=5
--lua-desync=multidisorder:ip_id=zero:pos=1,midsld:tcp_ack=-66000:strategy=6
--lua-desync=multidisorder:ip_id=zero:pos=midsld-1:seqovl=1:strategy=7
--lua-desync=multidisorder:ip_id=zero:pos=4:repeats=10:tcp_md5:strategy=8
--lua-desync=multidisorder:ip_id=zero:pos=1,host+2,sld+2,sld+5,sniext+1,sniext+2,endhost-2:seqovl=1:strategy=9
--lua-desync=multidisorder:ip_id=zero:pos=midsld,midsld+2:seqovl=1:tcp_md5:strategy=10

--new
--filter-udp=443
--filter-l7=quic
%BLOCKLIST%
%DOMAINS-EXCLUDE%
%IP-EXCLUDE%
--payload=quic_initial
--lua-desync=circular:fails=1:maxtime=30:udp_out=4:udp_in=4:reset
--lua-desync=fake:blob=QUIC_GOOGLE:repeats=6:payload=all:out_range=-n2:strategy=1
--lua-desync=fake:blob=QUIC_GOOGLE:repeats=6:payload=all:out_range=-d10:strategy=2
--lua-desync=fake:blob=QUIC_GOOGLE:repeats=6:payload=all:out_range=-d3:strategy=3
--lua-desync=fake:blob=fake_default_udp:repeats=2:payload=all:out_range=-d10:strategy=4
--lua-desync=fake:blob=fake_default_udp:payload=all:out_range=-d10:strategy=5
--lua-desync=fake:blob=fake_default_udp:repeats=6:payload=all:out_range=-n4:strategy=6
--lua-desync=fake:blob=fake_default_udp:payload=all:out_range=-n3:strategy=7

[messengers]
use_in>>game_mod

[game_mod]
--new
--filter-tcp=80,443,%GamePort%
%IP-SETLIST%
%DOMAINS-EXCLUDE%
%IP-EXCLUDE%
--payload=all
--lua-desync=circular:fails=1:maxtime=30:retrans=2:maxseq=16384:reset
--lua-desync=multidisorder:ip_id=zero:pos=1,midsld:strategy=1
--lua-desync=send:repeats=2:strategy=2
--lua-desync=multidisorder:ip_id=zero:pos=1,midsld:tcp_ack=-66000:strategy=3
--lua-desync=multidisorder:ip_id=zero:pos=1,midsld:ip_autottl=-1,3-20:ip6_autottl=-1,3-20:strategy=4
--lua-desync=multidisorder:ip_id=zero:pos=1,midsld:tcp_md5:strategy=5
--lua-desync=multidisorder:ip_id=zero:pos=1,midsld:tcp_ack=-66000:strategy=6
--lua-desync=multidisorder:ip_id=zero:pos=midsld-1:seqovl=1:strategy=7
--lua-desync=multidisorder:ip_id=zero:pos=4:repeats=10:tcp_md5:strategy=8
--lua-desync=multidisorder:ip_id=zero:pos=1,host+2,sld+2,sld+5,sniext+1,sniext+2,endhost-2:seqovl=1:strategy=9
--lua-desync=multidisorder:ip_id=zero:pos=midsld,midsld+2:seqovl=1:tcp_md5:strategy=10

--new
--filter-udp=%MessengersPortUPD%,%GamePort%
%IP-SETLIST%
%DOMAINS-EXCLUDE%
%IP-EXCLUDE%
--payload=all
--lua-desync=circular:fails=1:maxtime=30:udp_out=4:udp_in=4:reset
--lua-desync=fake:blob=QUIC_GOOGLE:repeats=6:payload=all:out_range=-n2:strategy=1
--lua-desync=fake:blob=QUIC_GOOGLE:repeats=6:payload=all:out_range=-d10:strategy=2
--lua-desync=fake:blob=fake_default_udp:repeats=6:payload=all:out_range=-d10:strategy=3
--lua-desync=fake:blob=fake_default_udp:repeats=6:payload=all:out_range=-n4:strategy=4
--lua-desync=fake:blob=fake_default_udp:payload=all:out_range=-n3:strategy=5